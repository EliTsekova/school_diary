@page
@model school_diary.Areas.Identity.Pages.Account.RegisterModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register | School Diary</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        body {
            background-color: #7db6db;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: "Segoe UI", sans-serif;
        }

        .login-wrapper {
            background-color: #e2eff7;
            padding: 2rem;
            border-radius: 12px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 0 15px rgba(0, 0, 0, 0.15);
            text-align: center;
        }

        .login-wrapper img {
            display: block;
            margin: 0 auto 1rem auto;
            height: 70px;
        }

        .nav-tabs .nav-link.active {
            background-color: #e2eff7;
            border-bottom: 2px solid #00b3b3;
            font-weight: bold;
        }

        .form-group i {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: #888;
        }

        .form-group input {
            padding-left: 2.2rem;
        }

        .btn-login {
            background-color: #27c1b8;
            color: white;
            border: none;
            border-radius: 5px;
        }

        .btn-login:hover {
            background-color: #1ca89f;
        }

        .form-select {
            padding-left: 2.2rem;
        }

        .select-icon {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: #888;
            z-index: 3;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <img src="~/images/logo_school_diary.png" alt="Logo" />

        <ul class="nav nav-tabs mb-4 justify-content-center border-0">
            <li class="nav-item">
                <a class="nav-link" asp-page="~/Identity/Account/Login">Login</a>
            </li>
            <li class="nav-item">
                <a class="nav-link active" asp-page="~/Identity/Account/Register">Register</a>
            </li>
        </ul>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success text-start">
                @TempData["SuccessMessage"]
            </div>
        }

        <form method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <div class="form-group position-relative mb-3">
                <i class="fas fa-user"></i>
                <input asp-for="Input.FirstName" class="form-control" placeholder="First Name" />
                <span asp-validation-for="Input.FirstName" class="text-danger"></span>
            </div>

            <div class="form-group position-relative mb-3">
                <i class="fas fa-user"></i>
                <input asp-for="Input.LastName" class="form-control" placeholder="Last Name" />
                <span asp-validation-for="Input.LastName" class="text-danger"></span>
            </div>

            <div class="form-group position-relative mb-3">
                <i class="fas fa-envelope"></i>
                <input asp-for="Input.Email" class="form-control" placeholder="Email" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group position-relative mb-3">
                <i class="fas fa-lock"></i>
                <input asp-for="Input.Password" type="password" class="form-control" placeholder="Password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-group position-relative mb-3">
                <i class="fas fa-lock"></i>
                <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="form-group position-relative mb-4">
                <i class="fas fa-user-tag select-icon"></i>
                <select asp-for="Input.Role" class="form-select">
                    <option value="">-- Select Role --</option>
                    <option value="Student">Student</option>
                    <option value="Parent">Parent</option>
                    <option value="Teacher">Teacher</option>
                    <option value="Director">Director</option>
                </select>
                <span asp-validation-for="Input.Role" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-login w-100">Register</button>
        </form>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
