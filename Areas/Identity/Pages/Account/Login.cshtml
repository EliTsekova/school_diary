@page
@model school_diary.Areas.Identity.Pages.Account.LoginModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | School Diary</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        body {
            background-color: #7db6db;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: "Segoe UI", sans-serif;
        }

        .login-wrapper {
            background-color: #e2eff7;
            padding: 2rem;
            border-radius: 12px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 0 15px rgba(0, 0, 0, 0.15);
            text-align: center;
        }

        .login-wrapper img {
            display: block;
            margin: 0 auto 1rem auto;
            height: 70px;
        }

        .form-group i {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: #888;
            z-index: 10;
        }

        .form-group input {
            padding-left: 2.2rem;
        }

        .btn-login {
            background-color: #27c1b8;
            color: white;
            border: none;
            border-radius: 5px;
            transition: 0.2s ease;
        }

        .btn-login:hover {
            background-color: #1ca89f;
            color: white;
        }
    </style>
</head>

<body>
    <div class="login-wrapper">
        <img src="~/images/logo_school_diary.png" alt="Logo" />

        <form onsubmit="handleLogin(event)" autocomplete="on">
            
            <div class="form-group position-relative mb-3">
                <i class="fas fa-user"></i>

                <input id="email"
                       name="email"
                       type="email"
                       class="form-control"
                       placeholder="Email"
                       autocomplete="username"
                       required />
            </div>

            <div class="form-group position-relative mb-3">
                <i class="fas fa-lock"></i>

                <input id="password"
                       name="password"
                       type="password"
                       class="form-control"
                       placeholder="Password"
                       autocomplete="current-password"
                       required />
            </div>

            <div class="form-check mb-3 text-start">
                <input id="rememberMe"
                       name="rememberMe"
                       type="checkbox"
                       class="form-check-input" />

                <label class="form-check-label" for="rememberMe">
                    Remember me
                </label>
            </div>

            <button type="submit" class="btn btn-login w-100">
                Log In
            </button>

            <div id="login-error"
                 class="alert alert-danger mt-3 d-none">
            </div>
        </form>
    </div>

    <script>
        async function handleLogin(event) {
            event.preventDefault();

            const email = document.getElementById("email").value;
            const password = document.getElementById("password").value;
            const errorBox = document.getElementById("login-error");

            errorBox.classList.add("d-none");
            errorBox.textContent = "";

            try {
                const response = await fetch("/api/Auth/login", {
                    method: "POST",
                    credentials: "include",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        email,
                        password
                    })
                });

                if (!response.ok) {
                    errorBox.textContent = "Invalid email or password.";
                    errorBox.classList.remove("d-none");
                    return;
                }

                const result = await response.json();

                if (result.role === "Admin") {
                    window.location.href = "/AdminUi/Index";
                }
                else if (result.role === "Teacher") {
                    window.location.href = "/TeacherUI/Index";
                }
                else if (result.role === "Director") {
                    window.location.href = "/DirectorUI/Index";
                }
                else if (result.role === "Parent") {
                    window.location.href = "/ParentUI/Index";
                }
                else if (result.role === "Student") {
                    window.location.href = "/StudentUI/Index";
                }
                else {
                    errorBox.textContent =
                        "No dashboard is available for role: " + result.role;

                    errorBox.classList.remove("d-none");
                }
            }
            catch {
                errorBox.textContent =
                    "An unexpected error occurred.";

                errorBox.classList.remove("d-none");
            }
        }
    </script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
