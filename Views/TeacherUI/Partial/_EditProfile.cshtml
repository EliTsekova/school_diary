@{
    Layout = null;
}
@model school_diary.Controllers.TeacherUIController.EditProfileInputModel

<form asp-controller="TeacherUI" asp-action="EditProfile" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Full Name</label>
        <input name="FullName" value="@Model.FullName" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <input name="Email" type="email" value="@Model.Email" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
</form>