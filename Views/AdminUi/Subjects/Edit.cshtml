@model school_diary.Dtos.SubjectDto

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Subject";
}

<h2>✏️ Edit Subject</h2>

<form asp-action="EditSubject" asp-route-id="@Model.Id" method="post" class="card card-form p-4">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Name</label>
        <input name="name" value="@Model.Name" class="form-control" required />
    </div>

    <button class="btn btn-primary">💾 Save</button>
    <a asp-action="Subjects" class="btn btn-secondary">Cancel</a>
</form>