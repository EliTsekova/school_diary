@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Director";
}

<h2>➕ Add Director</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@error.ErrorMessage</div>
        }
    </div>
}

<form asp-controller="AdminUi"
      asp-action="AddDirector"
      method="post"
      class="card card-form p-4">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">First Name</label>
        <input name="firstName"
               value="@(Context.Request.HasFormContentType ? Context.Request.Form["firstName"].ToString() : "")"
               class="form-control"
               required />
    </div>

    <div class="mb-3">
        <label class="form-label">Last Name</label>
        <input name="lastName"
               value="@(Context.Request.HasFormContentType ? Context.Request.Form["lastName"].ToString() : "")"
               class="form-control"
               required />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <input name="email"
               type="email"
               value="@(Context.Request.HasFormContentType ? Context.Request.Form["email"].ToString() : "")"
               class="form-control"
               required />
    </div>

    <div class="mb-3">
        <label class="form-label">Password</label>
        <input name="password"
               type="password"
               class="form-control"
               required />
    </div>

    <div class="mb-3">
        <label class="form-label">School</label>
        <select name="schoolId"
                asp-items="ViewBag.Schools"
                class="form-select"
                required>
            <option value="">-- Select school --</option>
        </select>
    </div>

    <button type="submit" class="btn btn-primary">
        💾 Save
    </button>

    <a asp-controller="AdminUi"
       asp-action="Directors"
       class="btn btn-secondary">
        Back
    </a>
</form>