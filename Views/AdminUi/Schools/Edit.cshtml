@model school_diary.Dtos.UpdateSchoolDto

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit School";
}

<h2>✏️ Edit School</h2>

<form asp-controller="AdminUi"
      asp-action="EditSchool"
      asp-route-id="@ViewBag.Id"
      method="post"
      class="card card-form p-4">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Name</label>

        <input asp-for="Name"
               class="form-control" />

        <span asp-validation-for="Name"
              class="text-danger">
        </span>
    </div>

    <div class="mb-3">
        <label asp-for="Address" class="form-label">Address</label>

        <input asp-for="Address"
               class="form-control" />

        <span asp-validation-for="Address"
              class="text-danger">
        </span>
    </div>

    <button type="submit"
            class="btn btn-primary">
        💾 Save
    </button>

    <a asp-controller="AdminUi"
       asp-action="Schools"
       class="btn btn-secondary mt-2">
        Cancel
    </a>
</form>