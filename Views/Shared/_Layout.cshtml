<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] – School Diary</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

    <style>
        body { font-family: "Segoe UI", sans-serif; background: #f4f7fa; overflow-x: hidden; }
        #sidebar { min-width: 250px; max-width: 250px; background: #003366; color: #fff; transition: all 0.3s; }
        #sidebar .sidebar-header { padding: 1rem; background: #002244; text-align: center; }
        #sidebar .nav-link { color: #ddd; padding: 0.75rem 1.25rem; }
        #sidebar .nav-link:hover { background: #004080; color: #fff; }
        #content { width: 100%; padding-left: 0; transition: all 0.3s; }
        #content header { background: #fff; padding: 0.75rem 1.25rem; border-bottom: 1px solid #dee2e6; display: flex; justify-content: space-between; align-items: center; }
        .sidebar-collapsed #sidebar { margin-left: -250px; }
    </style>
</head>

<body>
    <div class="d-flex" id="wrapper">
        <nav id="sidebar" class="vh-100">
            <div class="sidebar-header">
                <h4>SchoolDiary</h4>
            </div>

            <ul class="nav flex-column">
                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="AdminUi" asp-action="Index">
                            <i class="fa fa-home me-2"></i>Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Student" asp-action="AddStudent">
                            <i class="fa fa-user-graduate me-2"></i>Add Student
                        </a>

                        <a class="nav-link" asp-controller="Student" asp-action="ListStudent">
                            <i class="fa fa-list me-2"></i>Student List
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Teacher" asp-action="AddTeacher">
                            <i class="fa fa-chalkboard-teacher me-2"></i>Add Teacher
                        </a>

                        <a class="nav-link" asp-controller="Teacher" asp-action="ListTeacher">
                            <i class="fa fa-list me-2"></i>Teacher List
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Parent" asp-action="AddParent">
                            <i class="fa fa-user-friends me-2"></i>Add Parent
                        </a>

                        <a class="nav-link" asp-controller="Parent" asp-action="ListParent">
                            <i class="fa fa-list me-2"></i>Parent List
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Director" asp-action="AddDirector">
                            <i class="fa fa-user-tie me-2"></i>Add Director
                        </a>

                        <a class="nav-link" asp-controller="Director" asp-action="ListDirector">
                            <i class="fa fa-list me-2"></i>Director List
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="School" asp-action="AddSchool">
                            <i class="fa fa-school me-2"></i>Add School
                        </a>

                        <a class="nav-link" asp-controller="School" asp-action="ListSchool">
                            <i class="fa fa-list me-2"></i>School List
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Subject" asp-action="AddSubject">
                            <i class="fa fa-book me-2"></i>Add Subject
                        </a>

                        <a class="nav-link" asp-controller="Subject" asp-action="ListSubject">
                            <i class="fa fa-list me-2"></i>Subject List
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Curriculum" asp-action="AddCurriculum">
                            <i class="fa fa-project-diagram me-2"></i>Add Curriculum
                        </a>

                        <a class="nav-link" asp-controller="Curriculum" asp-action="ListCurriculum">
                            <i class="fa fa-list me-2"></i>Curriculum List
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Statistics" asp-action="Overview">
                            <i class="fa fa-chart-line me-2"></i>Statistics
                        </a>
                    </li>

                    <li class="nav-item mt-3">
                        <a class="nav-link" asp-controller="Profile" asp-action="EditProfile">
                            <i class="fa fa-user-cog me-2"></i>My Profile
                        </a>
                    </li>
                }
            </ul>
        </nav>

        <div id="content">
            <header>
                <button class="btn btn-outline-secondary" id="sidebarToggle">
                    <i class="fa fa-bars"></i>
                </button>

                <form asp-controller="AdminUi" asp-action="Logout" method="post" class="m-0">
                    <button type="submit" class="btn btn-outline-danger">
                        <i class="fa fa-sign-out-alt"></i> Logout
                    </button>
                </form>
            </header>

            <div class="content p-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('sidebarToggle').addEventListener('click', function () {
            document.getElementById('wrapper').classList.toggle('sidebar-collapsed');
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>

