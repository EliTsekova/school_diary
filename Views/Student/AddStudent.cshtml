@model school_diary.ViewModels.AddStudentViewModel

@{
    ViewData["Title"] = "Add Student";
}

<h2 class="text-primary">@ViewData["Title"]</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<form asp-action="AddStudent" method="post" class="mt-4">

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="FirstName" class="form-label">
            First Name
        </label>

        <input asp-for="FirstName" class="form-control" />

        <span asp-validation-for="FirstName"
              class="text-danger">
        </span>
    </div>

    <div class="mb-3">
        <label asp-for="LastName" class="form-label">
            Last Name
        </label>

        <input asp-for="LastName" class="form-control" />

        <span asp-validation-for="LastName"
              class="text-danger">
        </span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label">
            Email Address
        </label>

        <input asp-for="Email" class="form-control" />

        <span asp-validation-for="Email"
              class="text-danger">
        </span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label">
            Password
        </label>

        <input asp-for="Password"
               type="password"
               class="form-control" />

        <span asp-validation-for="Password"
              class="text-danger">
        </span>
    </div>

    <div class="mb-3">
        <label asp-for="SelectedSchoolId"
               class="form-label">
            School
        </label>

        <select asp-for="SelectedSchoolId"
                asp-items="Model.Schools"
                class="form-select">

            <option value="">
                -- Select School --
            </option>

        </select>

        <span asp-validation-for="SelectedSchoolId"
              class="text-danger">
        </span>
    </div>

    <div class="mb-3">
        <label asp-for="SelectedClassName"
               class="form-label">
            Class
        </label>

        <select asp-for="SelectedClassName"
                asp-items="Model.Classes"
                class="form-select">

            <option value="">
                -- Select Class --
            </option>

        </select>

        <span asp-validation-for="SelectedClassName"
              class="text-danger">
        </span>
    </div>

    <div class="d-flex gap-2">

        <button type="submit"
                class="btn btn-success">

            Save
        </button>

        <a asp-controller="AdminUi"
           asp-action="Students"
           class="btn btn-secondary">

            Back
        </a>

    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}